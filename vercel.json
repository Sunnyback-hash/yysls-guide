{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/ads.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/BingSiteAuth.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/ads.txt", "destination": "/ads.txt" },
    { "source": "/BingSiteAuth.xml", "destination": "/BingSiteAuth.xml" },
    { "source": "/market", "destination": "/market.html" },
    { "source": "/:path(newbie|articles|builds|maps|dungeons|clues|shefu|equipment|pvp|events|tools|community|admin)", "destination": "/index.html" }
  ]
}
