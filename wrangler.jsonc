{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yysls-guide-app",
  "compatibility_date": "2026-05-24",
  "main": "./_worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
