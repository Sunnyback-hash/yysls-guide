{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yysls-guide",
  "compatibility_date": "2026-05-24",
  "main": "./_worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
